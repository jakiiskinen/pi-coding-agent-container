# =============================================================================
# Pi Coding Agent - Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# --- Anthropic ---------------------------------------------------------------
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- GitHub ------------------------------------------------------------------
# Personal Access Token with scopes: repo, workflow
GITHUB_TOKEN=

# --- Git Identity ------------------------------------------------------------
GIT_NAME=Your Name
GIT_EMAIL=your.email@example.com
# GPG key ID for commit signing (optional, leave blank to disable)
GIT_GPG_KEY=
GIT_GPG_SIGN=false

# --- Azure VM (leave blank to use local Docker mode) -------------------------
AZURE_VM_RG=
AZURE_VM_NAME=
AZURE_VM_USER=azureuser
AZURE_VM_HOST=
# Set automatically by new-project.bat
AZURE_VM_PROJECT_PATH=

# --- Docker (Linux file permission mapping) ----------------------------------
# Run `id -u` and `id -g` on Linux/Mac to find your values (Windows: leave as 1000)
UID=1000
GID=1000
