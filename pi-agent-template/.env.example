# =============================================================================
# Pi Coding Agent - Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# --- Anthropic ---------------------------------------------------------------

ANTHROPIC_API_KEY=               # sk-ant-...

# --- GitHub ------------------------------------------------------------------

GITHUB_TOKEN=                    # Personal Access Token (scopes: repo, workflow)

# --- Git Identity ------------------------------------------------------------

GIT_NAME=Your Name
GIT_EMAIL=your.email@example.com
GIT_GPG_KEY=                     # GPG key ID for commit signing (optional)
GIT_GPG_SIGN=false               # Set to true to enable GPG commit signing

# --- Azure VM (leave blank to use local Docker mode) -------------------------

AZURE_VM_RG=                     # Resource group name
AZURE_VM_NAME=                   # VM name
AZURE_VM_USER=azureuser          # SSH username
AZURE_VM_HOST=                   # Static public IP
AZURE_VM_PROJECT_PATH=           # Set automatically by new-project.bat

# --- Docker (Linux file permission mapping) ----------------------------------

UID=1000                         # Run `id -u` to find your value
GID=1000                         # Run `id -g` to find your value
